# ─────────────────────────────────────────────────────────────────────────
# KaJota Coach × Casper — environment template
# Copy to `agent/.env.casper` and fill in. The agent loads `.env` /
# `.env.rapid-agent`; source this too (e.g. `set -a; . .env.casper; set +a`)
# or merge these keys into your existing env file.
# ─────────────────────────────────────────────────────────────────────────

# ─── x402 paywall (POST /coach/premium) ──────────────────────────────────
# The premium endpoint settles a CEP-18 micropayment on Casper through the
# CSPR.cloud x402 Facilitator. Without these the endpoint still returns 402,
# but explains it is unconfigured instead of charging.

# Facilitator base URL. Default works; same host serves mainnet + testnet.
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud

# CAIP-2 network: casper:casper-test (testnet, default) or casper:casper.
X402_NETWORK=casper:casper-test

# Recipient address — the "00"-prefixed Casper ACCOUNT HASH (not a public key;
# the facilitator rejects a raw pubkey as payTo). Derive it from your public
# key (blake2b: lower(algo) + 0x00 + key_bytes) then prefix "00". Fund the
# account with test CSPR at https://testnet.cspr.live/tools/faucet (one-time).
# (Example below = the KaJota demo account.)
X402_PAY_TO=000fd47bac4fe6a916a12e6676845e88b470591121bc33c8f04905b3e4d860b15b

# CEP-18 token PACKAGE hash (64 hex). MUST implement transfer_with_authorization
# (the EIP-712 extension Casper's x402 `exact` scheme signs) — a plain CEP-18
# won't settle. The value below is the canonical TESTNET "Wrapped CSPR" the
# Casper x402 reference servers use (verified live on CSPR.cloud, Jun 27, 2026).
# NOTE: /supported does NOT list assets — the asset is the merchant's choice.
X402_ASSET=3d80df21ba4ee4d66a2a1f60c32570dd5685e4b279f6538162a5fd1314847c1e

# Price in ATOMIC units. Wrapped CSPR has 9 decimals, so
# 1000000 = 0.001 WCSPR — the canonical "$0.001" micropayment.
X402_MAX_AMOUNT=1000000

# CEP-18 EIP-712 domain hints. `version` is MANDATORY (empty → facilitator
# rejects). `name` + `version` MUST match the on-chain contract or the
# settlement signature fails. For the testnet asset above: name="Wrapped CSPR".
X402_ASSET_NAME=Wrapped CSPR
X402_ASSET_VERSION=1
X402_ASSET_DECIMALS=9

# The facilitator's sponsored gas account for your network — from GET /supported
# (`python scripts/x402_demo.py --supported`). Testnet value (Jun 27, 2026):
X402_FEE_PAYER=81d557c9dcaadea97c34d79bf7b6af07aa9d760e5dd1aabf78a45fb39e072c3a

# Optional raw JSON merged over the asset hints above (advanced).
X402_ASSET_EXTRA=

# x402 envelope version. The live facilitator is on v2 (default); override
# only if it changes.
X402_VERSION=2

# Sponsored CSPR.cloud key — the buildathon issues one that unlocks the
# facilitator AND CSPR.cloud. Either name works; CSPR_CLOUD_API_KEY below is
# also accepted as a fallback.
X402_FACILITATOR_API_KEY=

# ─── Casper MCP toolset (agent on-chain awareness) ───────────────────────
# Adds msanlisavas/casper-mcp as a third MCP partner so the agent can read
# Casper on-chain state (balances, deploys, transfers, contracts). Runs the
# .NET MCP server via `docker run -i`, so it needs Docker on the host —
# great locally for the demo, off by default for the Render Python image.

# Set to 1/true to enable. Requires Docker + CSPR_CLOUD_API_KEY.
CASPER_MCP_ENABLED=0

# mainnet (default) or testnet — match X402_NETWORK for a coherent demo.
CASPER_MCP_NETWORK=testnet

# CSPR.cloud API key for the MCP server (and x402 fallback). Same sponsored
# key as above.
CSPR_CLOUD_API_KEY=
